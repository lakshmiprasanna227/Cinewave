# CineWave Environment Variables Template
# Copy this to .env and fill in your values

# Django Secret Key - Generate a new one for production
# Run: python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=your_secret_key_here

# Allowed hosts (comma-separated list)
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# TheMovieDB API Key (get from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key

# OMDB API Key (get from http://www.omdbapi.com/)
OMDB_API_KEY=your_omdb_api_key

# Optional: Database (using SQLite by default)
# DB_NAME=cinewave
# DB_USER=cinewave
# DB_PASSWORD=your_password
# DB_HOST=localhost
# DB_PORT=5432
